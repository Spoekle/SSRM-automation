{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSRM Automation",
  "version": "2.3.0-beta.1",
  "identifier": "com.spoekle.ssrm-automation",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSRM Automation",
        "width": 800,
        "height": 518,
        "minWidth": 800,
        "minHeight": 518,
        "resizable": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
